{
  "name": "webapp2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rimraf ../../build/webapp2",
    "start": "vite --host 0.0.0.0 --port 8080",
    "dev": "vite --host 0.0.0.0 --port 8080",
    "lint": "eslint -c .eslintrc.js \"**/*.{ts,tsx}\"",
    "lint:ts": "eslint -c .eslintrc.js \"src/main\"",
    "build": "npm run clean && vite build --outDir ../../build/webapp2",
    "build:local": "npm run clean && vite build --mode local --outDir ../../build/webapp2",
    "preview": "vite preview --host 0.0.0.0 --port 8081",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "2.2.7",
    "@sentry/react": "8.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "grapesjs": "^0.22.13",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-custom-code": "^1.0.1",
    "grapesjs-navbar": "^1.0.2",
    "grapesjs-plugin-forms": "^2.0.6",
    "grapesjs-preset-webpage": "^1.0.3",
    "grapesjs-style-bg": "^2.0.1",
    "grapesjs-tabs": "^1.0.6",
    "grapesjs-tooltip": "^0.1.8",
    "grapesjs-tui-image-editor": "^1.0.2",
    "highlight.js": "^11.10.0",
    "lucide-react": "^0.542.0",
    "next-themes": "^0.4.6",
    "posthog-js": "1.186.3",
    "react": "18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "react-redux": "8.1.3",
    "react-router-dom": "6.30.3",
    "react-toastify": "9.1.3",
    "remark-gfm": "^4.0.1",
    "remeda": "^2.33.6",
    "shiki": "^1.29.2",
    "stylis": "4.3.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "9.0.1",
    "websocket": "1.0.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@types/react-redux": "^7.1.34",
    "@types/uuid": "10.0.0",
    "@types/websocket": "^1.0.10",
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "@vitejs/plugin-react": "^5.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.34.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "rimraf": "6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "5.6.3",
    "vite": "^7.1.5",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.18"
  }
}
